{
  "name": "creem-datafast",
  "version": "0.1.0",
  "description": "Creem to DataFast bridge for checkout tracking and webhook forwarding.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js"
    },
    "./express": {
      "types": "./dist/express.d.ts",
      "import": "./dist/express.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/santigamo/creem-datafast.git"
  },
  "homepage": "https://github.com/santigamo/creem-datafast#readme",
  "bugs": {
    "url": "https://github.com/santigamo/creem-datafast/issues"
  },
  "keywords": [
    "creem",
    "datafast",
    "nextjs",
    "express",
    "webhooks",
    "payments",
    "analytics"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "pack:local": "pnpm build && pnpm pack --pack-destination .artifacts",
    "smoke:consumer": "node scripts/smoke-consumer.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "creem": "^1.4.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.6.5"
}
